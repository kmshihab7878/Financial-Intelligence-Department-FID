# Minimal environment for paper trading
# Copy to .env in the repo root: cp examples/paper_trading.env .env

# Required: HMAC secret for risk token signing
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AIS_RISK_HMAC_SECRET=CHANGE-ME-generate-a-real-secret

# Execution mode (paper = simulated fills, no exchange connection)
AIS_EXECUTION_MODE=paper

# API key for the control plane (generate a unique token)
AIS_API_KEY=CHANGE-ME-generate-a-real-api-key

# Redis (default works if Redis is running locally)
REDIS_URL=redis://localhost:6379/0

# Database path for event store
AIS_DB_PATH=data/ais_events.db

# Docker Compose passwords (only needed for docker compose up)
# AIS_DB_PASSWORD=changeme
# GF_ADMIN_PASSWORD=changeme
