# AIS Environment Configuration
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# --- Execution Mode ---
AIS_EXECUTION_MODE=paper
AIS_ENABLE_LIVE_TRADING=false

# --- MCP Server (required for shadow/live mode) ---
# URL of the Aster DEX MCP server
AIS_MCP_SERVER_URL=

# --- API Server ---
AIS_API_HOST=0.0.0.0
AIS_API_PORT=8000
AIS_PROMETHEUS_PORT=9001
AIS_LOG_LEVEL=INFO

# --- Security (required — generate with: python -c "import secrets; print(secrets.token_hex(32))") ---
AIS_API_KEY=
AIS_RISK_HMAC_SECRET=

# --- Aster DEX ---
ASTER_ACCOUNT_ID=

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379/0
AIS_DB_PATH=data/ais_events.db
AIS_DECISION_LOG_PATH=logs/decision_log.jsonl

# --- Database ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
AIS_DB_PASSWORD=

# --- Grafana ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
GF_ADMIN_PASSWORD=
