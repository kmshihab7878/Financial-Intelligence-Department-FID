# AIS Environment Configuration
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# --- Execution Mode ---
AIS_EXECUTION_MODE=paper
AIS_ENABLE_LIVE_TRADING=false

# --- MCP Server (required for shadow/live mode) ---
# URL of the Aster DEX MCP server
AIS_MCP_SERVER_URL=

# --- API Server ---
AIS_API_HOST=0.0.0.0
AIS_API_PORT=8000
AIS_PROMETHEUS_PORT=9001
AIS_LOOP_METRICS_PORT=9002
AIS_LOG_LEVEL=INFO

# --- Security (required — generate with: python -c "import secrets; print(secrets.token_hex(32))") ---
AIS_API_KEY=
AIS_RISK_HMAC_SECRET=
# Key rotation: set these when rotating the HMAC secret.
# 1. Copy current AIS_RISK_HMAC_SECRET to AIS_RISK_HMAC_SECRET_PREVIOUS
# 2. Generate a new AIS_RISK_HMAC_SECRET
# 3. Bump AIS_RISK_HMAC_KEY_ID (e.g., v1 -> v2)
# 4. After TTL (300s) elapses, remove AIS_RISK_HMAC_SECRET_PREVIOUS
AIS_RISK_HMAC_SECRET_PREVIOUS=
AIS_RISK_HMAC_KEY_ID=v1

# --- Aster DEX ---
ASTER_ACCOUNT_ID=

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379/0
AIS_DB_PATH=data/ais_events.db
AIS_DECISION_LOG_PATH=logs/decision_log.jsonl

# --- Secrets Provider (optional — default: environment variables) ---
# Path to a JSON secrets file (flat {"KEY": "value"} object)
AIS_SECRETS_FILE=
# Path to a directory of secret files (Kubernetes /var/run/secrets/ convention)
AIS_SECRETS_DIR=

# --- Alert Webhooks (optional) ---
# Slack incoming webhook URL for alert dispatch
AIS_SLACK_WEBHOOK_URL=
# Generic webhook URL for alert dispatch
AIS_ALERT_WEBHOOK_URL=

# --- Database ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
AIS_DB_PASSWORD=

# --- Grafana ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
GF_ADMIN_PASSWORD=
